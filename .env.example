# Copy this file to ".env" and fill in your Amplience API credentials.
# ".env" is git-ignored — it never gets committed or pushed.
#
# Option A: OAuth client credentials (preferred)
AMP_CLIENT_ID=
AMP_CLIENT_SECRET=

# Option B: a pre-obtained bearer token (instead of client id/secret)
# AMP_TOKEN=

# Optional overrides (defaults are usually correct):
# AMP_AUTH_URL=https://auth.amplience.net/oauth/token
# AMP_GRAPHQL_URL=https://api.amplience.net/graphql
# AMP_HUB_ID=
